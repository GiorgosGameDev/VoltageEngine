%%{init: {"theme":"base","themeVariables":{
  "background":"#14181f","primaryColor":"#1c222b","primaryTextColor":"#e8ebef",
  "primaryBorderColor":"#3a4453","lineColor":"#6b7686","secondaryColor":"#232b36",
  "tertiaryColor":"#1c222b","fontFamily":"ui-monospace, Menlo, monospace","fontSize":"14px"}}}%%
flowchart TD

  subgraph AUTH["AUTHORING &mdash; components you place in scenes"]
    direction LR
    SRC["AudioSourceComponent<br/>one-shots &middot; loops &middot; 3D<br/>fades &middot; low-pass &middot; reverb send"]
    ZONES["Zone components<br/>Ambience &middot; Crowd &middot; Music<br/>MixerSnapshot &middot; Reverb &middot; Ducking"]
    LIS["AudioListenerComponent<br/>(the ears)"]
  end

  subgraph MGR["Core.Audio &mdash; AudioManager (global manager)"]
    direction TB
    MIX["AudioMixer<br/>Master &rarr; Music / SFX / UI / Ambience / Voice<br/>volume &middot; mute &middot; solo"]
    VOICES["Voice management<br/>MaxVoices &middot; priority stealing<br/>distance culling &middot; virtual voices"]
    FX["Ducking &middot; Snapshots (moods)<br/>Reverb control &middot; per-voice fades"]
    MUSIC["MusicChannel<br/>crossfading streaming music"]
  end

  CLIP["AudioClip abstraction<br/>+ AudioDecoders &nbsp;wav / ogg / mp3&nbsp; (managed)"]

  subgraph BE["IAudioBackend &mdash; swappable seam"]
    direction LR
    MG["MonoGameAudioBackend<br/><b>default, all platforms</b><br/>one SoundEffectInstance per voice"]
    SW["SoftwareMixingAudioBackend<br/><b>opt-in &middot; real DSP</b><br/>SoftwareMixer &rarr; per-voice low-pass<br/>+ shared Freeverb &rarr; 1 DynamicSoundEffectInstance"]
  end

  OUT(["OpenAL &rarr; OS audio device<br/>Windows &middot; macOS &middot; Linux &middot; mobile / console"])

  SRC --> MGR
  ZONES --> MGR
  LIS -->|SetListener| VOICES
  MGR --> CLIP
  CLIP -->|"backend picks representation<br/>(SoundEffect or PCM)"| BE
  MGR --> BE
  MG --> OUT
  SW --> OUT
  SW -. "IsSupported? no &rarr; fall back" .-> MG

  classDef mgr fill:#1c222b,stroke:#f2b544,stroke-width:1.5px,color:#e8ebef;
  classDef dsp fill:#15211f,stroke:#4fd6c9,stroke-width:1.5px,color:#e8ebef;
  classDef out fill:#241d12,stroke:#f2b544,stroke-width:1.5px,color:#f2b544;
  class MIX,VOICES,FX,MUSIC mgr;
  class SW,CLIP dsp;
  class OUT out;
