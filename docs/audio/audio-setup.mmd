%%{init: {"theme":"base","themeVariables":{
  "background":"#14181f","primaryColor":"#1c222b","primaryTextColor":"#e8ebef",
  "primaryBorderColor":"#3a4453","lineColor":"#6b7686","secondaryColor":"#232b36",
  "tertiaryColor":"#1c222b","fontFamily":"ui-monospace, Menlo, monospace","fontSize":"14px"}}}%%
flowchart TB

  subgraph ONCE["① SET UP ONCE PER SCENE"]
    direction LR
    PLAYER["Player / Camera entity<br/>&nbsp;+ AudioListenerComponent&nbsp;<br/><i>exactly one &mdash; the ears</i>"]
    SETTINGS["Audio Settings entity (persistent)<br/>&nbsp;+ DialogueDuckingComponent&nbsp;<br/><i>global auto-duck config</i>"]
  end

  subgraph EMIT["② EMITTERS &mdash; place at the sound's location (no collider needed)"]
    direction LR
    SND["Sound entity<br/>&nbsp;+ AudioSourceComponent&nbsp;<br/>assign Clip &middot; tick Is3D for spatial<br/><i>Is3D draws a range gizmo</i>"]
    CROWD["Crowd entity<br/>&nbsp;+ CrowdEmitterComponent&nbsp;<br/>assign Clips[] &middot; Density &middot; Radius"]
  end

  subgraph ZONES["③ TRIGGER ZONES &mdash; each needs a trigger Collider on the SAME entity"]
    direction LR
    AMB["Ambience zone<br/>&nbsp;+ Collider (isTrigger)&nbsp;<br/>&nbsp;+ AmbienceZoneComponent&nbsp;<br/><i>looping bed, fades on enter/exit</i>"]
    MUS["Music zone<br/>&nbsp;+ Collider (isTrigger)&nbsp;<br/>&nbsp;+ MusicZoneComponent&nbsp;<br/><i>starts/crossfades a track</i>"]
    MOOD["Mood zone<br/>&nbsp;+ Collider (isTrigger)&nbsp;<br/>&nbsp;+ MixerSnapshotZoneComponent&nbsp;<br/><i>shifts whole-mix bus levels</i>"]
    REV["Reverb zone<br/>&nbsp;+ Collider (isTrigger)&nbsp;<br/>&nbsp;+ ReverbZoneComponent&nbsp;<br/><i>room reverb (software backend)</i>"]
  end

  NOTE["Rules of thumb:<br/>&bull; The Listener defines where sound is heard from &mdash; put it on whatever the player 'is'.<br/>&bull; Emitters are just placed in the world; the Listener's distance to them drives 3D volume &amp; pan.<br/>&bull; Every Zone fires when the Player's collider enters its trigger &mdash; so the Player needs a Collider too.<br/>&bull; Reverb &amp; occlusion low-pass are audible only with the software backend (PreferSoftwareBackend); harmless no-op otherwise."]

  PLAYER -. "moves through the world,<br/>entering trigger zones" .-> ZONES
  ONCE --> EMIT --> ZONES --> NOTE

  classDef ears fill:#1c222b,stroke:#f2b544,stroke-width:1.5px,color:#e8ebef;
  classDef emit fill:#15211f,stroke:#4fd6c9,stroke-width:1.4px,color:#e8ebef;
  classDef zone fill:#1c222b,stroke:#3a4453,stroke-width:1.2px,color:#e8ebef;
  classDef note fill:#241d12,stroke:#a67c2e,stroke-width:1px,color:#e8ebef;
  class PLAYER,SETTINGS ears;
  class SND,CROWD emit;
  class AMB,MUS,MOOD,REV zone;
  class NOTE note;
