# Force text diffs for all source files
*.cs        text eol=crlf
*.csproj    text eol=crlf
*.sln       text eol=crlf
*.json      text eol=crlf
*.xml       text eol=crlf
*.targets   text eol=crlf
*.props     text eol=crlf
*.md        text eol=crlf
*.txt       text eol=crlf
*.hlsl      text eol=crlf
*.fx        text eol=crlf

# Treat compiled/asset files as binary — no diff attempted
*.dll       binary
*.exe       binary
*.png       binary
*.jpg       binary
*.xnb       binary
*.mgcb      binary